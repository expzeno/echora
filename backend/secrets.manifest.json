{
  "provider": "gcp-secret-manager",
  "project": "labzeno-${ENV}",
  "secrets": [
    { "name": "DATABASE_URL", "secretId": "echora-${ENV}-database-url", "usedBy": "backend", "description": "PostgreSQL connection string" },
    { "name": "LOGS_DATABASE_URL", "secretId": "echora-${ENV}-database-url-logs", "usedBy": "backend", "description": "PostgreSQL connection string for audit/access logs DB" },
    { "name": "JWT_PRIVATE_KEY", "secretId": "echora-${ENV}-jwt-private", "usedBy": "backend", "description": "RS256 JWT signing key" },
    { "name": "JWT_PUBLIC_KEY", "secretId": "echora-${ENV}-jwt-public", "usedBy": "backend", "description": "RS256 JWT verification key" },
    { "name": "REDIS_URL", "secretId": "echora-${ENV}-redis-url", "usedBy": "backend", "description": "Redis connection string for cache and BullMQ queues" },
{ "name": "CYBERZENO_KEY", "secretId": "echora-${ENV}-cyberzeno-key", "usedBy": "backend", "description": "CyberZeno Node SDK API key" },
    { "name": "COS_SECRET_ID", "secretId": "echora-${ENV}-cos-secret-id", "usedBy": "backend", "description": "Tencent COS access key ID" },
    { "name": "COS_SECRET_KEY", "secretId": "echora-${ENV}-cos-secret-key", "usedBy": "backend", "description": "Tencent COS access key secret" }
  ]
}
