# ─── Core ───
PORT=37600
NODE_ENV=development

# ─── Database (Prisma 6 + Postgres) ───
DATABASE_URL=postgresql://server_tridentity_me:@localhost:5432/echora?connection_limit=20
LOGS_DATABASE_URL=postgresql://server_tridentity_me:@localhost:5432/echora_logs?connection_limit=5

# ─── Redis ───
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_PREFIX=echora

# ─── JWT (RS256) ───
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=30d

# ─── CORS ───
CORS_ORIGINS=

# ─── CyberZeno ───
CYBERZENO_ENDPOINT=https://cz.labzeno.com
CYBERZENO_KEY=

# ─── Tencent COS (Object Storage) ───
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=tv8-1316503238
COS_REGION=ap-singapore

# ─── Change-Log System ───
MODEL_LOG_HOOKS_ENABLED=true
LOG_WORKER_CONCURRENCY=3
IP_HASH_SECRET=beeff68f008148db7d0eb6369719f17bbadd992c18e90b08868ad293d17caf77

# ─── Retention (days) ───
RETENTION_ModelLog_DAYS=90
RETENTION_ApiAccessLog_DAYS=90
RETENTION_WebhookLog_DAYS=30

# ─── Google SSO ───
# Web OAuth client ID — used to verify tokens from all platforms
GOOGLE_WEB_CLIENT_ID=
# iOS OAuth client ID (different namespace from Firebase/FCM client IDs)
GOOGLE_IOS_CLIENT_ID=
# Android OAuth client ID (optional)
GOOGLE_ANDROID_CLIENT_ID=

# ─── Apple SSO ───
APPLE_APP_BUNDLE_ID=

# ─── Workers ───
INLINE_WORKER=true
