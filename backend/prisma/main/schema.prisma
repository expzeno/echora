generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Standard enums ───
enum UserRole {
  admin
  manager
  staff
  viewer
}

enum SessionPortal {
  customer
  merchant
  admin
}

// ─── Auth & Session (standard across all projects) ───
model User {
  id             Int        @id @default(autoincrement())
  email          String     @unique
  passwordHash   String     @map("password_hash")
  role           UserRole   @default(staff)
  jwtVersion     Int        @default(1) @map("jwt_version")
  isActive       Boolean    @default(true) @map("is_active")
  failedAttempts Int        @default(0) @map("failed_attempts")
  lockedUntil    DateTime?  @map("locked_until")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")
  sessions       Session[]

  @@map("users")
}

model Session {
  id           Int            @id @default(autoincrement())
  userId       Int?           @map("user_id")
  customerId   Int?           @map("customer_id")
  token        String         @unique
  refreshToken String?        @unique @map("refresh_token")
  portal       SessionPortal
  ip           String?        @db.VarChar(45)
  userAgent    String?        @map("user_agent") @db.VarChar(200)
  deviceLabel  String?        @map("device_label") @db.VarChar(100)
  isActive     Boolean        @default(true) @map("is_active")
  lastActiveAt DateTime       @default(now()) @map("last_active_at")
  expiresAt    DateTime       @map("expires_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  user         User?          @relation(fields: [userId], references: [id])
  customer     Customer?      @relation(fields: [customerId], references: [id])

  @@index([userId])
  @@index([customerId])
  @@index([expiresAt])
  @@map("sessions")
}

// ─── Business Models (demo) ───
// These demonstrate common patterns. Extend or replace for your domain.

enum CustomerStatus {
  pending
  active
  suspended
  banned
}

enum SSOProvider {
  google
  apple
}

enum MerchantStatus {
  active
  pending
  suspended
}

model Customer {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  passwordHash   String          @map("password_hash")
  displayName    String          @map("display_name") @db.VarChar(100)
  phoneNumber    String?         @map("phone_number") @db.VarChar(20)
  jwtVersion     Int             @default(1) @map("jwt_version")
  status         CustomerStatus  @default(active)
  isActive       Boolean         @default(true) @map("is_active")
  failedAttempts Int             @default(0) @map("failed_attempts")
  lockedUntil    DateTime?       @map("locked_until")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")
  emailVerified  Boolean         @default(false) @map("email_verified")
  sessions       Session[]
  devices        CustomerDevice[]
  notifications  Notification[]
  ssoLinks       CustomerSSO[]

  @@map("customers")
}

model CustomerSSO {
  id         Int         @id @default(autoincrement())
  customerId Int         @map("customer_id")
  provider   SSOProvider
  uid        String      @db.VarChar(255)
  createdAt  DateTime    @default(now()) @map("created_at")
  customer   Customer    @relation(fields: [customerId], references: [id])

  @@unique([provider, uid])
  @@index([customerId])
  @@map("customer_sso")
}

model Merchant {
  id           Int             @id @default(autoincrement())
  email        String          @unique
  displayName  String          @map("display_name") @db.VarChar(100)
  description  String?         @db.VarChar(500)
  phoneNumber  String?         @map("phone_number") @db.VarChar(20)
  address      String?         @db.VarChar(300)
  status       MerchantStatus  @default(pending)
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")

  @@map("merchants")
}

// ─── OTP (registration + password reset) ───
enum OtpType {
  register
  passwordReset
}

model OtpCode {
  id          Int       @id @default(autoincrement())
  email       String    @db.VarChar(255)
  codeHash    String    @map("code_hash")
  type        OtpType
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([email, type])
  @@map("otp_codes")
}

// ─── Push notifications (FCM device tokens) ───
enum DevicePlatform {
  ios
  android
  web
}

model CustomerDevice {
  id         Int             @id @default(autoincrement())
  customerId Int             @map("customer_id")
  fcmToken   String          @map("fcm_token") @db.VarChar(512)
  platform   DevicePlatform
  isActive   Boolean         @default(true) @map("is_active")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  customer   Customer        @relation(fields: [customerId], references: [id])

  @@unique([customerId, fcmToken])
  @@index([customerId])
  @@map("customer_devices")
}

// ─── In-app notifications ───
enum NotificationType {
  general
  transaction
  promotion
  system
}

model Notification {
  id         Int              @id @default(autoincrement())
  customerId Int              @map("customer_id")
  title      String           @db.VarChar(200)
  body       String           @db.VarChar(1000)
  type       NotificationType @default(general)
  isRead     Boolean          @default(false) @map("is_read")
  createdAt  DateTime         @default(now()) @map("created_at")
  customer   Customer         @relation(fields: [customerId], references: [id])

  @@index([customerId, createdAt])
  @@index([customerId, isRead])
  @@map("notifications")
}

// ═══════════════════════════════════════════════════════════════════
// Echora — WhatsApp customer support domain models (uuid ids)
// ═══════════════════════════════════════════════════════════════════

enum AgentRole {
  agent
  lead
  admin
}

enum AgentStatus {
  active
  suspended
}

enum ConversationStatus {
  open
  pending
  resolved
  closed
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageType {
  text
  image
  audio
  video
  document
  location
  template
  system
}

enum MessageStatus {
  queued
  sent
  delivered
  read
  failed
  received
}

enum IntegrationMode {
  sync
  async
}

// Support agent / lead / admin who handles WhatsApp conversations.
model Agent {
  id             String       @id @default(uuid()) @db.Uuid
  email          String       @unique
  passwordHash   String       @map("password_hash")
  displayName    String       @map("display_name") @db.VarChar(100)
  role           AgentRole    @default(agent)
  status         AgentStatus  @default(active)
  jwtVersion     Int          @default(1) @map("jwt_version")
  isActive       Boolean      @default(true) @map("is_active")
  failedAttempts Int          @default(0) @map("failed_attempts")
  lockedUntil    DateTime?    @map("locked_until")
  systemPrompt   String?      @map("system_prompt")
  model          String?      @default("claude-sonnet-4-6")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  conversations Conversation[]
  messages      Message[]

  @@index([role])
  @@map("agents")
}

// A business WhatsApp number (Meta WABA phone) that receives conversations.
model WhatsappNumber {
  id            String    @id @default(uuid()) @db.Uuid
  phoneNumber   String    @unique @map("phone_number") @db.VarChar(20)
  displayName   String    @map("display_name") @db.VarChar(100)
  wabaId        String?   @map("waba_id") @db.VarChar(64)
  phoneNumberId String?   @map("phone_number_id") @db.VarChar(64)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  conversations Conversation[]

  @@map("whatsapp_numbers")
}

// End customer identified by their WhatsApp id / phone number.
model Contact {
  id          String   @id @default(uuid()) @db.Uuid
  waId        String   @unique @map("wa_id") @db.VarChar(32)
  phoneNumber String?  @map("phone_number") @db.VarChar(20)
  displayName String?  @map("display_name") @db.VarChar(100)
  profileName String?  @map("profile_name") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  conversations Conversation[]
  messages      Message[]

  @@map("contacts")
}

// A support thread between a Contact and a WhatsappNumber, optionally assigned to an Agent.
model Conversation {
  id               String             @id @default(uuid()) @db.Uuid
  contactId        String             @map("contact_id") @db.Uuid
  whatsappNumberId String             @map("whatsapp_number_id") @db.Uuid
  assignedAgentId  String?            @map("assigned_agent_id") @db.Uuid
  status           ConversationStatus @default(open)
  lastMessageAt    DateTime?          @map("last_message_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  contact        Contact        @relation(fields: [contactId], references: [id])
  whatsappNumber WhatsappNumber @relation(fields: [whatsappNumberId], references: [id])
  assignedAgent  Agent?         @relation(fields: [assignedAgentId], references: [id])
  messages       Message[]

  @@index([contactId])
  @@index([whatsappNumberId])
  @@index([assignedAgentId])
  @@index([status, lastMessageAt])
  @@map("conversations")
}

// A single WhatsApp message within a conversation (inbound from contact or outbound from agent).
model Message {
  id             String           @id @default(uuid()) @db.Uuid
  conversationId String           @map("conversation_id") @db.Uuid
  senderAgentId  String?          @map("sender_agent_id") @db.Uuid
  contactId      String?          @map("contact_id") @db.Uuid
  waMessageId    String?          @unique @map("wa_message_id") @db.VarChar(128)
  direction      MessageDirection
  type           MessageType      @default(text)
  body           String?          @db.Text
  mediaUrl       String?          @map("media_url") @db.VarChar(500)
  status         MessageStatus    @default(received)
  createdAt      DateTime         @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])
  senderAgent  Agent?       @relation(fields: [senderAgentId], references: [id])
  contact      Contact?     @relation(fields: [contactId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderAgentId])
  @@index([contactId])
  @@index([status])
  @@map("messages")
}

// External system Echora forwards conversations/events to. v1 mode is ASYNC (webhook callback).
model ThirdPartyIntegration {
  id         String          @id @default(uuid()) @db.Uuid
  name       String          @db.VarChar(100)
  provider   String          @db.VarChar(64)
  mode       IntegrationMode @default(async)
  webhookUrl String?         @map("webhook_url") @db.VarChar(500)
  apiKey     String?         @map("api_key") @db.VarChar(255)
  config     Json?
  isActive   Boolean         @default(true) @map("is_active")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  deletedAt  DateTime?       @map("deleted_at")

  @@map("third_party_integrations")
}

// Canned responses agents can insert into the composer (quick replies).
model QuickReply {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(120)
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("quick_replies")
}

// ─── Add your business models below ───
// Conventions:
//   - Always use @@map("snake_case_table_name")
//   - Always use @map("snake_case") on camelCase fields
//   - Soft deletes: add `deletedAt DateTime? @map("deleted_at")`
//   - Monetary fields: use Decimal(16,2) — `@db.Decimal(16, 2)`
//   - Timestamps: createdAt + updatedAt on every model, deletedAt where needed
//   - Indexes: @@index on every FK column + composite indexes on query-hot column combos
//     (see CODING_STANDARD.md §33.8)
